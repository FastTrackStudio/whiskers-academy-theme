<!-- Meta Pixel Base Code -->
<script>
!function(f,b,e,v,n,t,s)
{if(f.fbq)return;n=f.fbq=function(){n.callMethod?
n.callMethod.apply(n,arguments):n.queue.push(arguments)};
if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
n.queue=[];t=b.createElement(e);t.async=!0;
t.src=v;s=b.getElementsByTagName(e)[0];
s.parentNode.insertBefore(t,s)}(window, document,'script',
'https://connect.facebook.net/en_US/fbevents.js');

fbq('init', '{{ settings.meta_pixel_id | escape }}');
fbq('track', 'PageView');

{%- assign featured_product = all_products[settings.product_handle] -%}
{%- if featured_product -%}
fbq('track', 'ViewContent', {
  content_ids: ['{{ featured_product.id }}'],
  content_name: {{ featured_product.title | json }},
  content_type: 'product',
  value: {{ featured_product.price | divided_by: 100.0 }},
  currency: '{{ cart.currency.iso_code }}'
});
{%- endif -%}
</script>
<noscript>
  <img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id={{ settings.meta_pixel_id | escape }}&ev=PageView&noscript=1"/>
</noscript>
<!-- End Meta Pixel Base Code -->
