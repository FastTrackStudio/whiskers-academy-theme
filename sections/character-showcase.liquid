<section class="characters section-pad" id="characters">
  <div class="container">
    <div class="section-header" data-reveal>
      <span class="section-eyebrow" style="color:var(--color-primary-light);">{{ section.settings.eyebrow }}</span>
      <h2 class="section-title" style="color:var(--color-white);">{{ section.settings.heading }}</h2>
      <p style="color:rgba(255,255,255,0.65);font-size:var(--text-lg);max-width:56ch;">{{ section.settings.subheading }}</p>
    </div>

    <div class="characters-strip">
      {%- for block in section.blocks -%}
        {%- if block.type == 'character' -%}
        <div class="character-card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 440 }}"
                 alt="{{ block.settings.name }}" loading="lazy"
                 style="width:100%;height:100%;object-fit:cover;display:block;position:absolute;inset:0;">
          {%- else -%}
            <div style="width:100%;height:100%;background:linear-gradient(160deg,var(--color-primary-dark),var(--color-dark));display:flex;align-items:center;justify-content:center;font-size:5rem;">{{ block.settings.emoji | default: '🐱' }}</div>
          {%- endif -%}
          <div class="character-card__overlay">
            <div class="character-card__name">{{ block.settings.name }}</div>
            <div class="character-card__career">{{ block.settings.career }}</div>
          </div>
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div style="text-align:center;margin-top:var(--space-8);" data-reveal>
      <a href="#buy-box" class="btn btn--teal">
        {%- assign _csph = settings.product_handle | default: 'whiskers-academy-card-game' -%}
        {%- assign _csv = all_products[_csph].first_available_variant -%}
        🎓 Get Your Copy — {%- if _csv and _csv.compare_at_price > _csv.price and settings.pre_order_mode -%}<s style="opacity:0.6;font-weight:400">{{ _csv.compare_at_price | money }}</s> {%- elsif settings.original_price != blank and settings.pre_order_mode -%}<s style="opacity:0.6;font-weight:400">${{ settings.original_price }}</s> {%- endif -%}{%- if _csv -%}{{ _csv.price | money }}{%- else -%}${{ settings.sale_price | default: '23.99' }}{%- endif -%}
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Character Showcase",
  "settings": [
    { "type": "text",     "id": "eyebrow",    "label": "Eyebrow",    "default": "The Cast" },
    { "type": "text",     "id": "heading",    "label": "Heading",    "default": "Meet Your Classmates" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Hand-drawn cat scholars with personality and bite. Each one has their own strategy — and their own agenda." }
  ],
  "blocks": [
    {
      "type": "character",
      "name": "Character",
      "settings": [
        { "type": "image_picker", "id": "image",  "label": "Character image" },
        { "type": "text",         "id": "emoji",  "label": "Fallback emoji",  "default": "🐱" },
        { "type": "text",         "id": "name",   "label": "Character name",  "default": "Professor Mittens" },
        { "type": "text",         "id": "career", "label": "Dream career",    "default": "Dean of Chaos" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Character Showcase",
      "blocks": [
        { "type": "character", "settings": { "emoji": "🎩", "name": "Professor Mittens", "career": "Dean of Chaos" } },
        { "type": "character", "settings": { "emoji": "💼", "name": "Lady Fluffington", "career": "Corporate Spy" } },
        { "type": "character", "settings": { "emoji": "📚", "name": "Sir Whiskers III", "career": "Academic Swindler" } },
        { "type": "character", "settings": { "emoji": "🎭", "name": "Duchess Pawsworth", "career": "Drama Professor" } },
        { "type": "character", "settings": { "emoji": "🔬", "name": "Dr. Tabby", "career": "Mad Scientist" } },
        { "type": "character", "settings": { "emoji": "⚖️", "name": "Judge Claw", "career": "Student Parliament" } }
      ]
    }
  ]
}
{% endschema %}
