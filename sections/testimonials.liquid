<section class="testimonials section-pad" id="testimonials">
  <div class="container">
    <div class="section-header text-center" data-reveal>
      <span class="section-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="section-title">{{ section.settings.heading }}</h2>
    </div>

    <div class="testimonials__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
        <div class="testimonial-card" data-reveal {{ block.shopify_attributes }}>
          <div class="testimonial-card__stars">
            {%- assign stars = block.settings.stars | default: 5 -%}
            {%- for i in (1..stars) -%}⭐{%- endfor -%}
          </div>
          <p class="testimonial-card__body">{{ block.settings.review }}</p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar">
              {%- if block.settings.avatar != blank -%}
                <img src="{{ block.settings.avatar | image_url: width: 88 }}"
                     alt="{{ block.settings.name }}" loading="lazy">
              {%- else -%}
                {{ block.settings.name | slice: 0 | upcase }}
              {%- endif -%}
            </div>
            <div>
              <div class="testimonial-card__name">{{ block.settings.name }}</div>
              <div class="testimonial-card__tag">{{ block.settings.tag }}</div>
            </div>
          </div>
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "eyebrow",  "label": "Eyebrow",  "default": "Early Players" },
    { "type": "text", "id": "heading",  "label": "Heading",  "default": "What Early Players Are Saying" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range",       "id": "stars",  "label": "Stars",       "min": 1, "max": 5, "default": 5 },
        { "type": "textarea",    "id": "review", "label": "Review text",  "default": "This game had us cackling from the first round. My cat actually watched us play — clearly impressed." },
        { "type": "image_picker","id": "avatar", "label": "Avatar photo (optional)" },
        { "type": "text",        "id": "name",   "label": "Name",         "default": "Sarah K." },
        { "type": "text",        "id": "tag",    "label": "Tag (e.g. Cat mom · Board game fanatic)", "default": "Cat mom · Board game fanatic" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "review", "settings": { "stars": 5, "review": "This game had us cackling from the first round. My cat actually watched us play — clearly impressed.", "name": "Sarah K.", "tag": "Cat mom · Board game fanatic" } },
        { "type": "review", "settings": { "stars": 5, "review": "Setup in 60 seconds, impossible to put down. We played until midnight and none of us had work the next day. Worth it.", "name": "Marcus T.", "tag": "Exploding Kittens veteran" } },
        { "type": "review", "settings": { "stars": 5, "review": "Finally a game my kids AND I are both actually competitive at. The card art alone is worth the price of admission.", "name": "Priya M.", "tag": "Parent · Card game collector" } }
      ]
    }
  ]
}
{% endschema %}
