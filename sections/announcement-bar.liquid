{% if section.settings.show_bar %}
<div class="announcement-bar" role="banner">
  <div class="announcement-bar__inner container">
    {%- if section.settings.badge_text != blank -%}
      <span class="announcement-bar__badge">{{ section.settings.badge_text }}</span>
    {%- endif -%}
    <span>{{ section.settings.message }}</span>
    {%- if settings.pre_order_mode and section.settings.show_scarcity -%}
      <span class="announcement-bar__limited">
        {{ section.settings.scarcity_text | replace: '{{count}}', settings.stock_display_count }}
      </span>
    {%- endif -%}
    {%- if section.settings.link_text != blank and section.settings.link_url != blank -%}
      <a href="{{ section.settings.link_url }}" class="announcement-bar__link">{{ section.settings.link_text }} →</a>
    {%- endif -%}
  </div>
</div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    { "type": "checkbox", "id": "show_bar", "label": "Show announcement bar", "default": true },
    { "type": "text", "id": "badge_text", "label": "Badge label (e.g. 🎓 PRE-ORDER)", "default": "🎓 PRE-ORDER" },
    { "type": "text", "id": "message", "label": "Message", "default": "Paws Up — Limited First Edition. Estimated Shipping June 2026." },
    { "type": "checkbox", "id": "show_scarcity", "label": "Show scarcity text (pre-order mode only)", "default": true },
    { "type": "text", "id": "scarcity_text", "label": "Scarcity text (use {{count}} for the number)", "default": "Only {{count}} copies left at this price!" },
    { "type": "text", "id": "link_text", "label": "Link text (optional)" },
    { "type": "url", "id": "link_url", "label": "Link URL (optional)" }
  ]
}
{% endschema %}
