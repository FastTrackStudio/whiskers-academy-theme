<section class="founders section-pad" id="founders">
  <div class="container">
    <div class="founders__inner">

      <!-- Photo -->
      <div class="founders__photo" data-reveal>
        {%- if section.settings.photo != blank -%}
          <img src="{{ section.settings.photo | image_url: width: 800 }}"
               alt="{{ section.settings.photo_alt | default: 'Emiel and Lisa, creators of Whiskers Academy' }}"
               width="800" loading="lazy"
               style="aspect-ratio:1/1;width:100%;max-width:100%;object-fit:cover;border-radius:var(--radius-xl);display:block;">
        {%- else -%}
          <div style="aspect-ratio:1/1;width:100%;max-width:100%;background:linear-gradient(160deg,var(--color-primary-light),var(--color-cream));border-radius:var(--radius-xl);display:flex;align-items:center;justify-content:center;font-size:6rem;">👩‍💼🐱👨‍💼</div>
        {%- endif -%}
        {%- if section.settings.badge_text != blank -%}
        <div class="founders__photo-badge">
          {{ section.settings.badge_text }}
        </div>
        {%- endif -%}
      </div>

      <!-- Story -->
      <div class="founders__story" data-reveal>
        <span class="section-eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 class="section-title">{{ section.settings.heading }}</h2>
        {%- for block in section.blocks -%}
          {%- if block.type == 'paragraph' -%}
          <p class="founders__bio" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
          {%- endif -%}
        {%- endfor -%}
        {%- if section.settings.show_cta -%}
        <a href="#buy-box" class="btn btn--teal">
          {%- assign _fsph = settings.product_handle | default: 'whiskers-academy-card-game' -%}
          {%- assign _fsv = all_products[_fsph].first_available_variant -%}
          🐾 Support Our Game — Pre-Order {%- if _fsv and _fsv.compare_at_price > _fsv.price -%}<s style="opacity:0.6;font-weight:400">{{ _fsv.compare_at_price | money }}</s> {%- elsif settings.original_price != blank -%}<s style="opacity:0.6;font-weight:400">${{ settings.original_price }}</s> {%- endif -%}{%- if _fsv -%}{{ _fsv.price | money }}{%- else -%}${{ settings.sale_price | default: '23.99' }}{%- endif -%}
        </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Founder Story",
  "settings": [
    { "type": "image_picker", "id": "photo",      "label": "Founder photo" },
    { "type": "text",         "id": "photo_alt",  "label": "Photo alt text",   "default": "Emiel and Lisa, creators of Whiskers Academy" },
    { "type": "text",         "id": "badge_text", "label": "Photo badge text (optional)", "default": "Two humans\ntrying to impress\ntheir cats 🐱" },
    { "type": "text",         "id": "eyebrow",    "label": "Eyebrow",         "default": "Our Story" },
    { "type": "text",         "id": "heading",    "label": "Heading",         "default": "Meet The Creators" },
    { "type": "checkbox",     "id": "show_cta",   "label": "Show CTA button", "default": true }
  ],
  "blocks": [
    {
      "type": "paragraph",
      "name": "Paragraph",
      "settings": [
        { "type": "textarea", "id": "text", "label": "Paragraph text" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Founder Story",
      "blocks": [
        { "type": "paragraph", "settings": { "text": "We are Emiel and Lisa from Whiskers Academy — two humans trying to impress their cats. We built a fast, expandable card game that treats humor and strategy like lab partners." } },
        { "type": "paragraph", "settings": { "text": "During a quiet holiday with no TV, we turned to card games for fun. We enjoyed it so much that we decided to create our own. As artists in the video game industry and lifelong board game fans, we combined our love for cats, career humor, and strategy to create Whiskers Academy — all under the watchful eyes of our own cats." } },
        { "type": "paragraph", "settings": { "text": "After many brainstorming sessions and sticky notes, we found our perfect theme. Some characters are even inspired by our real cats, past and present — a heartfelt tribute. Now it's time to share Whiskers Academy with the world!" } }
      ]
    }
  ]
}
{% endschema %}
