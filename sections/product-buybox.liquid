{%- assign _ph = settings.product_handle | default: 'whiskers-academy-card-game' -%}
{%- assign _product = all_products[_ph] -%}
{%- assign _variant = _product.first_available_variant -%}

<section class="buybox section-pad" id="buy-box">
  <div class="container">
    <div class="buybox__inner">

      <!-- Image Gallery -->
      <div class="buybox__gallery" data-reveal>
        <div class="gallery-main">
          <button class="gallery-main__lightbox-trigger" aria-label="Open image lightbox" data-lightbox-open>
            <img id="mainGalleryImg"
                 src="{%- if section.settings.image_1 != blank -%}{{ section.settings.image_1 | image_url: width: 800 }}{%- elsif _product.featured_image -%}{{ _product.featured_image | image_url: width: 800 }}{%- endif -%}"
                 alt="{{ section.settings.product_title }}"
                 width="800" loading="eager">
            <span class="gallery-main__zoom-hint" aria-hidden="true">🔍</span>
          </button>
        </div>

        <!-- Thumbnails -->
        <div class="gallery-thumbs">
          {%- if section.settings.image_1 != blank -%}
            <div class="gallery-thumb is-active"
                 data-src="{{ section.settings.image_1 | image_url: width: 800 }}"
                 data-index="0">
              <img src="{{ section.settings.image_1 | image_url: width: 144 }}" alt="View 1" loading="lazy">
            </div>
          {%- endif -%}
          {%- if section.settings.image_2 != blank -%}
            <div class="gallery-thumb"
                 data-src="{{ section.settings.image_2 | image_url: width: 800 }}"
                 data-index="1">
              <img src="{{ section.settings.image_2 | image_url: width: 144 }}" alt="View 2" loading="lazy">
            </div>
          {%- endif -%}
          {%- if section.settings.image_3 != blank -%}
            <div class="gallery-thumb"
                 data-src="{{ section.settings.image_3 | image_url: width: 800 }}"
                 data-index="2">
              <img src="{{ section.settings.image_3 | image_url: width: 144 }}" alt="View 3" loading="lazy">
            </div>
          {%- endif -%}
          {%- if section.settings.image_4 != blank -%}
            <div class="gallery-thumb"
                 data-src="{{ section.settings.image_4 | image_url: width: 800 }}"
                 data-index="3">
              <img src="{{ section.settings.image_4 | image_url: width: 144 }}" alt="View 4" loading="lazy">
            </div>
          {%- endif -%}
          {%- if section.settings.image_5 != blank -%}
            <div class="gallery-thumb"
                 data-src="{{ section.settings.image_5 | image_url: width: 800 }}"
                 data-index="4">
              <img src="{{ section.settings.image_5 | image_url: width: 144 }}" alt="View 5" loading="lazy">
            </div>
          {%- endif -%}
          {%- if section.settings.image_6 != blank -%}
            <div class="gallery-thumb"
                 data-src="{{ section.settings.image_6 | image_url: width: 800 }}"
                 data-index="5">
              <img src="{{ section.settings.image_6 | image_url: width: 144 }}" alt="View 6" loading="lazy">
            </div>
          {%- endif -%}
        </div>
      </div>

      <!-- Image Lightbox Overlay -->
      <div class="gallery-lightbox" id="galleryLightbox" role="dialog" aria-modal="true" aria-label="Image viewer" hidden>
        <div class="gallery-lightbox__backdrop" data-lightbox-close></div>
        <button class="gallery-lightbox__btn gallery-lightbox__close" data-lightbox-close aria-label="Close">✕</button>
        <button class="gallery-lightbox__btn gallery-lightbox__prev" data-lightbox-prev aria-label="Previous image">&#8592;</button>
        <button class="gallery-lightbox__btn gallery-lightbox__next" data-lightbox-next aria-label="Next image">&#8594;</button>
        <div class="gallery-lightbox__frame">
          <img class="gallery-lightbox__img" id="lightboxImg" src="" alt="Product image">
        </div>
      </div>

      <!-- Buy Info -->
      <div class="buybox__info" data-reveal>
        <!-- Pre-order tag (top label) -->
        <span class="buybox__tag">
          {%- if settings.pre_order_mode -%}📦 Pre-Order — Ships {{ settings.pre_order_ship_date }}{%- else -%}✅ In Stock{%- endif -%}
        </span>

        <h2 class="buybox__title">{{ section.settings.product_title }}</h2>
        <p class="buybox__tagline">{{ section.settings.product_tagline }}</p>

        <!-- Promo badge -->
        {%- if settings.show_promo_badge and settings.pre_order_mode -%}
        <div id="promoRibbon" style="display:inline-flex;align-items:center;gap:0.5rem;background:linear-gradient(90deg,#E07A5F,#F2A65A);color:#fff;font-family:var(--font-display);font-weight:800;font-size:0.9rem;padding:0.35rem 1rem;border-radius:999px;margin-bottom:0.75rem;box-shadow:0 3px 12px rgba(224,122,95,0.4);">
          {{ settings.promo_badge_text }}
        </div>
        {%- endif -%}

        <!-- Price -->
        {%- assign _markup_pct = section.settings.compare_markup | default: 25 -%}
        {%- assign _fake_compare = _variant.price | times: 100 | plus: _variant.price | times: _markup_pct | divided_by: 100 -%}
        {%- comment %}Simpler calculation: price * (100 + markup) / 100 in one step{%- endcomment -%}
        {%- assign _fake_compare = _variant.price | times: _markup_pct | divided_by: 100 | plus: _variant.price | round -%}
        <div class="buybox__price-row">
          <span class="buybox__price">
            {%- if _variant -%}
              {%- if _variant.compare_at_price > _variant.price -%}
                <s style="opacity:0.5;font-size:1.1rem;font-weight:400;margin-right:0.4rem;">{{ _variant.compare_at_price | money }}</s>
              {%- elsif section.settings.compare_markup > 0 -%}
                <s style="opacity:0.5;font-size:1.1rem;font-weight:400;margin-right:0.4rem;">{{ _fake_compare | money }}</s>
              {%- endif -%}
              {{ _variant.price | money }}
            {%- else -%}
              —
            {%- endif -%}
          </span>
        </div>

        <!-- Stock -->
        <div class="buybox__stock">🔴 Only {{ settings.stock_display_count }} copies left at this price</div>

        <!-- Add to Cart / Pre-Order Button -->
        {%- if _product != blank -%}
          <button class="btn btn--primary btn--lg buybox__add-btn btn--pulse"
                  data-add-to-cart
                  data-variant-id="{{ _variant.id }}"
                  {%- if _variant.available == false -%} disabled {%- endif -%}>
            {%- if settings.pre_order_mode -%}
              🐾 Pre-Order Now — {%- if _variant.compare_at_price > _variant.price -%}<s style="opacity:0.6;font-weight:400;">{{ _variant.compare_at_price | money }}</s> {%- elsif section.settings.compare_markup > 0 -%}<s style="opacity:0.6;font-weight:400;">{{ _fake_compare | money }}</s> {%- endif -%}{{ _variant.price | money }}
            {%- elsif _variant.available -%}
              🛒 Buy Now — {{ _variant.price | money }}
            {%- else -%}
              Sold Out
            {%- endif -%}
          </button>
        {%- else -%}
          <a href="{{ section.settings.buy_url | default: '/cart' }}"
             class="btn btn--primary btn--lg buybox__add-btn btn--pulse">
          🐾 Pre-Order Now
          </a>
        {%- endif -%}

        <!-- Guarantees -->
        <div class="buybox__guarantees">
          {%- for block in section.blocks -%}
            {%- if block.type == 'guarantee' -%}
              <span class="guarantee-chip" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <!-- Pre-order explainer accordion -->
        {%- if settings.pre_order_mode -%}
        <div class="preorder-accordion">
          <button class="preorder-accordion__trigger" aria-expanded="false">
            <span>❓ How does pre-ordering work?</span>
            <span class="chevron">▾</span>
          </button>
          <div class="preorder-accordion__body">
            <p>{{ section.settings.preorder_explainer }}</p>
          </div>
        </div>
        {%- endif -%}

        <!-- What's in the box -->
        {%- if section.settings.whats_in_box != blank -%}
        <div style="margin-top:1.5rem;">
          <p style="font-family:var(--font-display);font-weight:700;margin-bottom:0.5rem;">📦 What's in the box:</p>
          <p style="color:var(--color-mid);font-size:0.9rem;">{{ section.settings.whats_in_box }}</p>
        </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Buy Box",
  "settings": [
    { "type": "header", "content": "Product" },
    {
      "type": "text", "id": "product_title",
      "label": "Product name",
      "default": "Whiskers Academy Card Game"
    },
    {
      "type": "textarea", "id": "product_tagline",
      "label": "Tagline (below title)",
      "default": "The expandable card game where cats chase their dream careers. For 2–6 players, ages 10+."
    },
    {
      "type": "text", "id": "price",
      "label": "Fallback display price (if theme price settings are blank)",
      "default": "23.99"
    },
    {
      "type": "url", "id": "buy_url",
      "label": "Fallback Buy URL (if no Shopify product)"
    },
    { "type": "header", "content": "Gallery Images (up to 6)" },
    { "type": "image_picker", "id": "image_1", "label": "Gallery image 1 (main)" },
    { "type": "image_picker", "id": "image_2", "label": "Gallery image 2" },
    { "type": "image_picker", "id": "image_3", "label": "Gallery image 3" },
    { "type": "image_picker", "id": "image_4", "label": "Gallery image 4" },
    { "type": "image_picker", "id": "image_5", "label": "Gallery image 5" },
    { "type": "image_picker", "id": "image_6", "label": "Gallery image 6" },
    { "type": "header", "content": "Pre-order Info" },
    {
      "type": "textarea", "id": "preorder_explainer",
      "label": "Pre-order explainer text",
      "default": "You pay today and your card is charged immediately. Your game will be produced and shipped in June 2026. You'll receive email updates along the way. Cancellations are accepted up to 30 days after purchase."
    },
    {
      "type": "text", "id": "whats_in_box",
      "label": "What's in the box",
      "default": "100+ illustrated cards · Rules booklet · Durable game box · Character reference cards"
    },
    { "type": "header", "content": "Strikethrough Price" },
    {
      "type": "range", "id": "compare_markup",
      "label": "Show fake 'was' price (% above sale price)",
      "info": "E.g. 25 = show a strikethrough price that is 25% higher than the sale price. Set to 0 to hide. Ignored if the Shopify product already has a Compare at price set.",
      "min": 0, "max": 80, "step": 5, "default": 25, "unit": "%"
    }
  ],
  "blocks": [
    {
      "type": "guarantee",
      "name": "Guarantee Badge",
      "settings": [
        { "type": "text", "id": "text", "label": "Badge text", "default": "🔒 Secure Checkout" }
      ]
    }
  ],
  "presets": [{
    "name": "Product Buy Box",
    "blocks": [
      { "type": "guarantee", "settings": { "text": "🔒 Secure Checkout" } },
      { "type": "guarantee", "settings": { "text": "🌍 Worldwide Shipping" } },
      { "type": "guarantee", "settings": { "text": "📦 Ships June 2026" } },
      { "type": "guarantee", "settings": { "text": "⭐ Satisfaction Guaranteed" } }
    ]
  }]
}
{% endschema %}
