<section class="second-cta section-pad" id="join-academy">
  <div class="container">
    <div class="second-cta__inner">
      <div data-reveal>
        <span class="section-eyebrow" style="color:var(--color-primary-light);">{{ section.settings.eyebrow }}</span>
        <h2 class="second-cta__title">{{ section.settings.heading }}</h2>
        <p class="second-cta__sub">{{ section.settings.subheading }}</p>
      </div>

      <div class="second-cta__actions" data-reveal>
        <a href="#buy-box" class="btn btn--primary btn--lg btn--pulse">
          {%- if settings.pre_order_mode -%}🐾 Pre-Order Now — $29.99{%- else -%}🛒 Buy Now — $29.99{%- endif -%}
        </a>
        {%- if settings.kickstarter_url != blank -%}
        <a href="{{ settings.kickstarter_url }}" class="btn btn--ghost btn--lg" target="_blank" rel="noopener">
          🚀 Follow on Kickstarter
        </a>
        {%- endif -%}
      </div>

      {%- if section.settings.show_email_form -%}
      <div data-reveal>
        <p style="color:rgba(255,255,255,0.6);font-size:var(--text-sm);margin-bottom:var(--space-4);">{{ section.settings.email_cta }}</p>
        <form class="email-form" action="#" method="post" novalidate>
          <input class="email-form__input"
                 type="email"
                 name="email"
                 placeholder="{{ section.settings.email_placeholder }}"
                 autocomplete="email"
                 required>
          <button class="email-form__btn" type="submit">{{ section.settings.email_btn }}</button>
        </form>
        <p style="color:rgba(255,255,255,0.35);font-size:var(--text-xs);margin-top:var(--space-3);">No spam. Unsubscribe anytime.</p>
      </div>
      {%- endif -%}

      <!-- Social Links -->
      <div class="social-links" data-reveal>
        {%- if settings.instagram_url != blank -%}
          <a href="{{ settings.instagram_url }}" class="social-link" target="_blank" rel="noopener">
            📸 Instagram
          </a>
        {%- endif -%}
        {%- if settings.tiktok_url != blank -%}
          <a href="{{ settings.tiktok_url }}" class="social-link" target="_blank" rel="noopener">
            🎵 TikTok
          </a>
        {%- endif -%}
        {%- if settings.youtube_url != blank -%}
          <a href="{{ settings.youtube_url }}" class="social-link" target="_blank" rel="noopener">
            ▶ YouTube
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Second CTA",
  "settings": [
    { "type": "text",     "id": "eyebrow",           "label": "Eyebrow",              "default": "Don't Miss Out" },
    { "type": "text",     "id": "heading",           "label": "Heading",              "default": "Class Is About to Begin 🎓" },
    { "type": "textarea", "id": "subheading",        "label": "Subheading",           "default": "Pre-order your copy now. Limited first edition. Ships June 2026." },
    { "type": "checkbox", "id": "show_email_form",   "label": "Show email signup",    "default": true },
    { "type": "text",     "id": "email_cta",         "label": "Email form label",     "default": "Or sign up for launch updates & campus gossip:" },
    { "type": "text",     "id": "email_placeholder", "label": "Email placeholder",    "default": "your@email.com" },
    { "type": "text",     "id": "email_btn",         "label": "Email button text",    "default": "Keep Me Posted" }
  ],
  "presets": [{ "name": "Second CTA" }]
}
{% endschema %}
