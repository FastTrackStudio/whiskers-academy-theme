<section class="second-cta section-pad" id="join-academy" style="position:relative;overflow:hidden;">
  {%- if section.settings.bg_image != blank -%}
    <div style="position:absolute;inset:0;background-image:url('{{ section.settings.bg_image | image_url: width: 1920 }}');background-size:cover;background-position:center;z-index:0;"></div>
    <div style="position:absolute;inset:0;background:rgba(0,0,0,{{ section.settings.overlay_opacity | default: 55 | divided_by: 100.0 }});z-index:1;"></div>
  {%- endif -%}
  <div class="container" style="position:relative;z-index:2;">
    <div class="second-cta__inner">
      <div data-reveal style="text-align:center;">
        <span class="section-eyebrow" style="color:var(--color-primary-light);display:block;text-align:center;">{{ section.settings.eyebrow }}</span>
        <h2 class="second-cta__title" style="text-align:center;">{{ section.settings.heading }}</h2>
        <p class="second-cta__sub" style="text-align:center;margin-inline:auto;">{{ section.settings.subheading }}</p>
      </div>

      <div class="second-cta__actions" data-reveal>
        <a href="#buy-box" class="btn btn--primary btn--lg btn--pulse">
          {%- if settings.pre_order_mode -%}
            🐾 Pre-Order Now — {%- if settings.original_price != blank -%}<s style="opacity:0.6;font-weight:400">${{ settings.original_price }}</s> {%- endif -%}${{ settings.sale_price | default: '23.99' }}
          {%- else -%}
            🛒 Buy Now — ${{ settings.sale_price | default: '23.99' }}
          {%- endif -%}
        </a>
        {%- if settings.kickstarter_url != blank -%}
        <a href="{{ settings.kickstarter_url }}" class="btn btn--ghost btn--lg" target="_blank" rel="noopener">
          🚀 Follow on Kickstarter
        </a>
        {%- endif -%}
      </div>

      {%- if section.settings.show_email_form -%}
      <div class="text-center" data-reveal style="text-align:center;">
        <p style="color:rgba(255,255,255,0.6);font-size:var(--text-sm);margin-bottom:var(--space-4);text-align:center;margin-inline:auto;">{{ section.settings.email_cta }}</p>
        <form class="email-form" action="/contact#contact_form" id="contact_form" method="post" accept-charset="UTF-8" novalidate style="margin-inline:auto;">
          <input type="hidden" name="form_type" value="customer">
          <input type="hidden" name="utf8" value="✓">
          <input type="hidden" name="customer[accepts_marketing]" value="1">
          <input type="hidden" name="customer[tags]" value="newsletter">
          <input class="email-form__input"
                 type="email"
                 name="customer[email]"
                 placeholder="{{ section.settings.email_placeholder }}"
                 autocomplete="email"
                 required>
          <button class="email-form__btn" type="submit">{{ section.settings.email_btn }}</button>
        </form>
        <p style="color:rgba(255,255,255,0.35);font-size:var(--text-xs);margin-top:var(--space-3);text-align:center;margin-inline:auto;">No spam. Unsubscribe anytime.</p>
      </div>
      {%- endif -%}

      <!-- Social Links -->
      <div class="social-links" data-reveal>
        {%- if settings.instagram_url != blank -%}
          <a href="{{ settings.instagram_url }}" class="social-link" target="_blank" rel="noopener">
            📸 Instagram
          </a>
        {%- endif -%}
        {%- if settings.youtube_url != blank -%}
          <a href="{{ settings.youtube_url }}" class="social-link" target="_blank" rel="noopener">
            ▶ YouTube
          </a>
        {%- endif -%}
        {%- if settings.facebook_url != blank -%}
          <a href="{{ settings.facebook_url }}" class="social-link" target="_blank" rel="noopener">
            📘 Facebook
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>


{% schema %}
{
  "name": "Second CTA",
  "settings": [
    { "type": "image_picker", "id": "bg_image",          "label": "Background image" },
    { "type": "range",        "id": "overlay_opacity",   "label": "Image overlay darkness", "min": 0, "max": 90, "step": 5, "default": 55, "unit": "%" },
    { "type": "text",     "id": "eyebrow",           "label": "Eyebrow",              "default": "Don't Miss Out" },
    { "type": "text",     "id": "heading",           "label": "Heading",              "default": "Class Is About to Begin 🎓" },
    { "type": "textarea", "id": "subheading",        "label": "Subheading",           "default": "Pre-order your copy now. Limited first edition. Ships June 2026." },
    { "type": "checkbox", "id": "show_email_form",   "label": "Show email signup",    "default": true },
    { "type": "text",     "id": "email_cta",         "label": "Email form label",     "default": "Or sign up for launch updates & campus gossip:" },
    { "type": "text",     "id": "email_placeholder", "label": "Email placeholder",    "default": "your@email.com" },
    { "type": "text",     "id": "email_btn",         "label": "Email button text",    "default": "Keep Me Posted" }
  ],
  "presets": [{ "name": "Second CTA" }]
}
{% endschema %}

