                "faq-1": {
                    "type": "faq_item",
                    "settings": {
                        "question": "When will my order ship?",
                        "answer": "We estimate shipping in June 2026. You'll receive email updates at every milestone."
                    }
                },
                "faq-2": {
                    "type": "faq_item",
                    "settings": {
                        "question": "What's included in the box?",
                        "answer": "100+ illustrated cards, a full-colour rules booklet, character reference cards, and a sturdy game box."
                    }
                },
                "faq-3": {
                    "type": "faq_item",
                    "settings": {
                        "question": "How many players and how long does it take?",
                        "answer": "Designed for 2–6 players. Setup takes 1 minute, rounds run 15–30 minutes."
                    }
                },
                "faq-4": {
                    "type": "faq_item",
                    "settings": {
                        "question": "Do you ship worldwide?",
                        "answer": "Yes! We ship worldwide (excluding regions with active conflict or import restrictions)."
                    }
                },
                "faq-5": {
                    "type": "faq_item",
                    "settings": {
                        "question": "Can I cancel my pre-order?",
                        "answer": "Yes — we accept cancellations up to 30 days after your order. After that, orders enter production."
                    }
                },
                "faq-6": {
                    "type": "faq_item",
                    "settings": {
                        "question": "Will there be expansions?",
                        "answer": "Yes! Future expansions, an NSFW version, and collectible plush characters are all in the pipeline."
                    }
                }
            },
