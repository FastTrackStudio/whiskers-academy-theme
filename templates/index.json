        "founders": {
            "type": "founder-story",
            "blocks": {
                "p-1": {
                    "type": "paragraph",
                    "settings": {
                        "text": "We are Emiel and Lisa from Whiskers Academy — two humans trying to impress their cats. We built a fast, expandable card game that treats humor and strategy like lab partners."
                    }
                },
                "p-2": {
                    "type": "paragraph",
                    "settings": {
                        "text": "During a quiet holiday with no TV, we turned to card games for fun. We enjoyed it so much that we decided to create our own. As artists in the video game industry and lifelong board game fans, we combined our love for cats, career humor, and strategy to create Whiskers Academy."
                    }
                },
                "p-3": {
                    "type": "paragraph",
                    "settings": {
                        "text": "After many brainstorming sessions and sticky notes, we found our perfect theme. Some characters are even inspired by our real cats — a heartfelt tribute. Now it's time to share Whiskers Academy with the world!"
                    }
                }
            },
            "block_order": [
                "p-1",
                "p-2",
                "p-3"
            ],
            "settings": {}
