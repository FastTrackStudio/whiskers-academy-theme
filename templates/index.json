            "blocks": {
                "row-1": {
                    "type": "feature_row",
                    "settings": {
                        "fallback_emoji": "📚",
                        "title": "Build Your Deck & Study Up",
                        "body": "Choose your cat scholar and build your purr-sonal deck. Earn education cards that bring you closer to your dream career.",
                        "bullet_1": "Build skills through education cards",
                        "bullet_2": "Counter surprise exams from rivals",
                        "bullet_3": "Protect your progress at all costs"
                    }
                },
                "row-2": {
                    "type": "feature_row",
                    "settings": {
                        "fallback_emoji": "😼",
                        "title": "Scheme, Bluff & Outsmart",
                        "body": "Books double as weapons. Gossip rules the halls. Every card is a calculated risk — or a delicious gamble.",
                        "bullet_1": "Steal advantages from classmates",
                        "bullet_2": "Bluff your way through exams",
                        "bullet_3": "Time your moves for maximum chaos"
                    }
                },
                "row-3": {
                    "type": "feature_row",
                    "settings": {
                        "fallback_emoji": "🏆",
                        "title": "Graduate & Claim Top Cat",
                        "body": "First to meet their graduation requirements claims the title of Top Cat. Will you study hard, cheat boldly, or do both?",
                        "bullet_1": "Meet your graduation requirements",
                        "bullet_2": "Defend your position in the final stretch",
                        "bullet_3": "Claim the title of Top Cat!"
                    }
